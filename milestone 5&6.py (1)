import time
import random
import logging
import asyncio
from abc import ABC, abstractmethod
from typing import List, Tuple, Any
from dataclasses import dataclass
from concurrent.futures import ProcessPoolExecutor

logging.basicConfig(level=logging.INFO, format="%(asctime)s [%(levelname)s] (%(threadName)s) %(message)s")
logger = logging.getLogger("MLPipeline_Phase3")

# Phase imports & structural requirements
@dataclass
class SensorReading:
    timestamp: float
    machine_id: str
    temperature: float
    vibration: float
    rotation_speed: float
    label: int = 0


class PredictionStrategy(ABC):
    @abstractmethod
    def fit(self, features: List[List[float]], labels: List[int]) -> None:
        pass
    @abstractmethod
    def predict(self, feature_row: List[float]) -> int:
        pass


class ThresholdHeuristicStrategy(PredictionStrategy):
    def __init__(self):
        self.is_trained = False
        self.temp_threshold = 90.0

    def fit(self, features: List[List[float]], labels: List[int]) -> None:
        failures = [features[i][0] for i in range(len(features)) if labels[i] == 1]
        self.temp_threshold = sum(failures) / len(failures) if failures else 90.0
        self.is_trained = True
        logger.info(f"Strategy calibrated. Temp threshold updated: {self.temp_threshold:.2f}°C")

    def predict(self, feature_row: List[float]) -> int:
        return 1 if feature_row[0] > self.temp_threshold else 0


# =====================================================================
# MILESTONE 5: Concurrency & High-Performance Systems (Weeks 11-13)
# =====================================================================

class ConcurrentDataEngine:
    """Manages parallel processing and asynchronous real-time streaming."""

    @staticmethod
    def _parallel_feature_extraction(chunk: List[SensorReading]) -> List[Tuple[List[float], int]]:
        """Static worker function suitable for pickling across system processes."""
        results = []
        for reading in chunk:
            features = [reading.temperature, reading.vibration, reading.rotation_speed]
            results.append((features, reading.label))
        return results

    def scale_feature_engineering(self, data: List[SensorReading], workers: int = 2) -> List[Tuple[List[float], int]]:
        """Distributes processing loads using a ProcessPoolExecutor."""
        chunk_size = max(1, len(data) // workers)
        chunks = [data[i:i + chunk_size] for i in range(0, len(data), chunk_size)]
        
        logger.info(f"Scaling pipeline calculations across {workers} parallel processes...")
        all_features = []
        with ProcessPoolExecutor(max_workers=workers) as executor:
            results = executor.map(self._parallel_feature_extraction, chunks)
            for res in results:
                all_features.extend(res)
        return all_features

    async def async_fetch_realtime_metrics(self, machine_id: str) -> SensorReading:
        """Asynchronous non-blocking simulator representing streaming physical sensor metric feeds."""
        await asyncio.sleep(0.1)  # Simulates I/O network interface latency
        return SensorReading(time.time(), machine_id, 
                             random.uniform(70.0, 115.0), 
                             random.uniform(4.0, 16.0), 
                             random.uniform(1500, 3500))


# =====================================================================
# MILESTONE 6: Research Contribution & Final System (Week 14)
# =====================================================================

class AdaptiveOnlineMLPipeline:
    """
    Research Innovation: An adaptive online predictor implementing a self-correction feedback loop.
    It continuously monitors active accuracy metrics and triggers on-the-fly model recalibration.
    """
    def __init__(self, model_strategy: PredictionStrategy):
        self.model = model_strategy
        self.concurrency_engine = ConcurrentDataEngine()
        
        # Real-time Evaluation History Tracking Metrics
        self.prediction_history: List[int] = []
        self.ground_truth_history: List[int] = []

    def run_dynamic_recalibration(self, features: List[List[float]], labels: List[int]) -> None:
        """Dynamically updates model properties using fresh, real-time ground truth observations."""
        self.model.fit(features, labels)

    def evaluate_precision(self) -> float:
        """Calculates current historical model prediction accuracy."""
        if not self.prediction_history:
            return 0.0
        correct = sum(1 for p, g in zip(self.prediction_history, self.ground_truth_history) if p == g)
        return (correct / len(self.prediction_history)) * 100


# =====================================================================
# PHASE 3 EXECUTION HARNESS (ASYNCIO MAIN LOOP)
# =====================================================================
async def main():
    logger.info("=== STARTING PHASE 3 (MILESTONES 5 & 6) ===")
    
    # Setup baseline data
    mock_sensor_data = [
        SensorReading(time.time(), "MACH_001", random.uniform(65, 110), random.uniform(2, 15), 1800, 1 if random.random() > 0.8 else 0)
        for _ in range(100)
    ]
    
    adaptive_system = AdaptiveOnlineMLPipeline(ThresholdHeuristicStrategy())
    
    # Milestone 5: Parallel Process Execution Benchmarking
    start_t = time.perf_counter()
    extracted_features = adaptive_system.concurrency_engine.scale_feature_engineering(mock_sensor_data, workers=2)
    end_t = time.perf_counter()
    logger.info(f"⏱️  Multiprocess Compilation completed in: {end_t - start_t:.4f} seconds")

    # Initial offline calibration
    X_train = [item[0] for item in extracted_features]
    y_train = [item[1] for item in extracted_features]
    adaptive_system.run_dynamic_recalibration(X_train, y_train)

    # Milestone 6: Asynchronous Streaming Loop and Adaptive Prediction Feedback
    logger.info("Starting adaptive monitoring simulation...")
    for _ in range(5):
        # Async retrieve next streaming record
        incoming_reading = await adaptive_system.concurrency_engine.async_fetch_realtime_metrics("MACH_001")
        sample_feature = [incoming_reading.temperature, incoming_reading.vibration, incoming_reading.rotation_speed]
        
        # Predict & Track results
        prediction = adaptive_system.model.predict(sample_feature)
        ground_truth = incoming_reading.label
        
        adaptive_system.prediction_history.append(prediction)
        adaptive_system.ground_truth_history.append(ground_truth)
        
        logger.info(f"Stream telemetry metrics processed -> Predicted class: {prediction} (True: {ground_truth})")
        
    final_accuracy = adaptive_system.evaluate_precision()
    logger.info(f"=== FINAL SYSTEM METRIC VALIDATION ACCURACY: {final_accuracy:.2f}% ===")
    logger.info("=== PHASE 3 SYSTEM RUN COMPLETE ===")

if __name__ == "__main__":
    asyncio.run(main())